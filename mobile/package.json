{
  "name": "strikeiq-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "refresh-data": "python ../scripts/export_mobile_data.py",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
